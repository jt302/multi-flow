{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "multi-flow",
	"version": "0.2.9",
	"identifier": "io.multiflow.app",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"withGlobalTauri": false,
		"windows": [
			{
				"label": "main",
				"title": "Multi-Flow",
				"width": 1300,
				"height": 800,
				"create": false,
				"visible": false,
				"acceptFirstMouse": true
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:* http://localhost:* ws://localhost:*; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
			"dangerousDisableAssetCspModification": false,
			"assetProtocol": {
				"enable": true,
				"scope": [
					"$APPDATA/plugins/packages/**",
					"$APPDATA/dev/plugins/packages/**",
					"$APPDATA/screenshots/**",
					"$APPDATA/dev/screenshots/**",
					"$APPDATA/automation_data/**",
					"$APPDATA/dev/automation_data/**",
					"$APPDATA/chat-attachments/**",
					"$APPDATA/dev/chat-attachments/**"
				]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": ["app", "dmg"],
		"createUpdaterArtifacts": true,
		"licenseFile": "../LICENSE",
		"resources": {
			"../docs/default-skills": "default-skills"
		},
		"externalBin": ["binaries/multi-flow-sync-manager"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"hardenedRuntime": true
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxRjA0RTJGM0QwQkI3RjMKUldUenR3czlMMDd3d1E4OEtqNE93UWY0d1FyY0l3N0QvSWVyclhnMzdqY2orTGJJblZ6bzVoQTIK",
			"endpoints": [
				"https://github.com/jt302/multi-flow/releases/latest/download/latest.json"
			]
		}
	}
}
