{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for main, log and RPA editor windows",
  "windows": ["main", "log-panel", "rpa-flow-editor", "automation-canvas-*"],
  "permissions": [
    "core:default",
    "core:app:allow-set-app-theme",
    "core:window:allow-close",
    "opener:default",
    "window-state:default",
    "dialog:default"
  ]
}
